{
  "name": "vinu",
  "version": "0.3.0",
  "private": true,
  "description": "Voice-driven notetaking with local Whisper + cloud LLM",
  "author": {
    "name": "Sumanth Dodda",
    "email": "hellosumo@blekcipher.com"
  },
  "homepage": "https://github.com/sumododda/vinu",
  "repository": {
    "type": "git",
    "url": "https://github.com/sumododda/vinu.git"
  },
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "package": "electron-vite build && electron-builder",
    "package:mac": "electron-vite build && electron-builder --mac",
    "package:win": "electron-vite build && electron-builder --win",
    "package:linux": "electron-vite build && electron-builder --linux",
    "fetch:sidecars": "node scripts/fetch-sidecars.mjs",
    "gen:icon": "node scripts/gen-icon.mjs",
    "postinstall": "electron-builder install-app-deps",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@fontsource-variable/public-sans": "^5.2.7",
    "@fontsource/libre-bodoni": "^5.2.7",
    "better-sqlite3": "^12.9.0",
    "marked": "^18.0.2",
    "openai": "^6.34.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@playwright/test": "^1.59.1",
    "@resvg/resvg-js": "^2.6.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^10.2.1",
    "jsdom": "^29.0.2",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "^6.0.3",
    "vite": "^7.3.2",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "@electron/asar": "^4.2.0",
    "@electron/get": "^4.0.3",
    "global-agent": "^4.1.3",
    "cacache": "^20.0.4"
  }
}
